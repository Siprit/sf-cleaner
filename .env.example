# ── Salesforce (JWT Bearer OAuth) ─────────────────────────────────────────────
SF_USERNAME=your-sf-username@example.com
SF_CONSUMER_KEY=your-connected-app-consumer-key
SF_PRIVATE_KEY_PATH=./certs/sf_private_key.pem   # path to RSA private key
SF_DOMAIN=login                                    # or 'test' for sandbox

# ── LinkedIn Sales Navigator ───────────────────────────────────────────────────
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
LINKEDIN_ACCESS_TOKEN=your-linkedin-access-token   # long-lived token

# ── Email verification ────────────────────────────────────────────────────────
ZEROBOUNCE_API_KEY=your-zerobounce-api-key   # primary verifier
NEVERBOUNCE_API_KEY=your-neverbounce-api-key  # fallback verifier

# ── ZoomInfo ───────────────────────────────────────────────────────────────────
ZOOMINFO_CLIENT_ID=your-zoominfo-client-id
ZOOMINFO_PRIVATE_KEY=your-zoominfo-private-key
# Leave blank to use stub adapter during development
ZOOMINFO_ENABLED=false

# ── Apollo ────────────────────────────────────────────────────────────────────
APOLLO_API_KEY=your-apollo-api-key
# Third-priority fallback after LinkedIn + ZoomInfo
APOLLO_ENABLED=false

# ── Vector DB ─────────────────────────────────────────────────────────────────
# Choose: "pinecone" or "pgvector"
VECTOR_BACKEND=pgvector

# Pinecone (if VECTOR_BACKEND=pinecone)
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX=sf-cleaner-leads
PINECONE_ENV=us-east-1-aws

# pgvector (if VECTOR_BACKEND=pgvector — uses POSTGRES_* below)

# ── Embeddings (OpenAI text-embedding-3-small) ─────────────────────────────────
OPENAI_API_KEY=your-openai-api-key

# ── PostgreSQL (pgvector + audit log) ─────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=sfcleaner
POSTGRES_USER=sfcleaner
POSTGRES_PASSWORD=sfcleaner

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b

# ── Vector cache ──────────────────────────────────────────────────────────────
CACHE_TTL_DAYS=90
CACHE_SIMILARITY_THRESHOLD=0.92

# ── Confidence threshold ──────────────────────────────────────────────────────
# Leads scored >= threshold are auto-written to Salesforce; below → review queue
CONFIDENCE_THRESHOLD=0.80

# ── Enrichment batch size ─────────────────────────────────────────────────────
BATCH_SIZE=1000

# ── Intent webhook ────────────────────────────────────────────────────────────
# HMAC-SHA256 secret shared with the signal provider
INTENT_WEBHOOK_SECRET=your-webhook-secret
